DATABASE_URL="postgresql://user:pass@localhost:5432/aigen"
DIRECT_URL="postgresql://user:pass@localhost:5432/aigen"
REDIS_URL="redis://localhost:6379"
AUTH_SECRET="your-auth-secret"
OPENAI_API_KEY="sk-or-v1-..."
HF_TOKEN="hf_..."
REMOVEBG_API_KEY=""

# S3 (Cloudflare R2 or compatible)
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Worker
WORKER_URL=https://your-worker.railway.app
PORT=8080

# Public URL
NEXT_PUBLIC_URL=http://localhost:3000

# XorPay (支付宝/微信支付)
XORPAY_AID=your_app_id
XORPAY_SECRET=your_app_secret

# Stripe (国际支付，可选)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (for email verification & password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@example.com

# Replicate
REPLICATE_API_TOKEN=
